{
  "title": "CryptoExchange — Infraestructura",
  "uid": "crypto-infra",
  "tags": ["crypto", "infra"],
  "timezone": "browser",
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "CPU por contenedor",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "rate(container_cpu_usage_seconds_total{image!=\"\"}[1m]) * 100",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "percent", "max": 100 }
      }
    },
    {
      "id": 2,
      "title": "Memoria por contenedor (MB)",
      "type": "timeseries",
      "gridPos": { "x": 12, "y": 0, "w": 12, "h": 8 },
      "targets": [{
        "expr": "container_memory_usage_bytes{image!=\"\"} / 1024 / 1024",
        "legendFormat": "{{name}}"
      }],
      "fieldConfig": {
        "defaults": { "unit": "decmbytes" }
      }
    },
    {
      "id": 3,
      "title": "CPU host total",
      "type": "gauge",
      "gridPos": { "x": 0, "y": 8, "w": 8, "h": 5 },
      "targets": [{
        "expr": "100 - (avg by(instance) (rate(node_cpu_seconds_total{mode=\"idle\"}[1m])) * 100)",
        "legendFormat": "CPU %"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 60 },
              { "color": "red",    "value": 80 }
            ]
          }
        }
      }
    },
    {
      "id": 4,
      "title": "RAM host libre (GB)",
      "type": "gauge",
      "gridPos": { "x": 8, "y": 8, "w": 8, "h": 5 },
      "targets": [{
        "expr": "node_memory_MemAvailable_bytes / 1024 / 1024 / 1024",
        "legendFormat": "RAM libre"
      }],
      "fieldConfig": {
        "defaults": { "unit": "decgbytes", "min": 0 }
      }
    },
    {
      "id": 5,
      "title": "Disco usado (%)",
      "type": "gauge",
      "gridPos": { "x": 16, "y": 8, "w": 8, "h": 5 },
      "targets": [{
        "expr": "100 - (node_filesystem_avail_bytes{mountpoint=\"/\"} / node_filesystem_size_bytes{mountpoint=\"/\"} * 100)",
        "legendFormat": "Disco /"
      }],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "steps": [
              { "color": "green",  "value": 0  },
              { "color": "yellow", "value": 70 },
              { "color": "red",    "value": 90 }
            ]
          }
        }
      }
    },
    {
      "id": 6,
      "title": "Network I/O host (bytes/s)",
      "type": "timeseries",
      "gridPos": { "x": 0, "y": 13, "w": 24, "h": 7 },
      "targets": [
        {
          "expr": "rate(node_network_receive_bytes_total{device!~\"lo|docker.*\"}[1m])",
          "legendFormat": "↓ recv {{device}}"
        },
        {
          "expr": "rate(node_network_transmit_bytes_total{device!~\"lo|docker.*\"}[1m])",
          "legendFormat": "↑ send {{device}}"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "Bps" }
      }
    },
    {
      "id": 7,
      "title": "Micro-batches Spark procesados",
      "type": "stat",
      "gridPos": { "x": 0, "y": 20, "w": 8, "h": 4 },
      "targets": [{
        "expr": "spark_microbatches_total",
        "legendFormat": "Total batches"
      }]
    },
    {
      "id": 8,
      "title": "Duración media micro-batch (p95)",
      "type": "stat",
      "gridPos": { "x": 8, "y": 20, "w": 8, "h": 4 },
      "targets": [{
        "expr": "histogram_quantile(0.95, rate(spark_batch_duration_seconds_bucket[5m]))",
        "legendFormat": "p95"
      }],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 9,
      "title": "Errores WebSocket",
      "type": "stat",
      "gridPos": { "x": 16, "y": 20, "w": 8, "h": 4 },
      "targets": [{
        "expr": "producer_errores_ws_total",
        "legendFormat": "Errores WS"
      }],
      "fieldConfig": {
        "defaults": {
          "thresholds": {
            "steps": [
              { "color": "green", "value": 0 },
              { "color": "red",   "value": 1 }
            ]
          }
        }
      }
    }
  ]
}
